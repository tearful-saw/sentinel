# Telegram API (required for --dry-run and --live modes)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=

# Bankr API (required for --live mode, also enables LLM Gateway)
BANKR_API_KEY=

# Uniswap API (free, get at developers.uniswap.org)
UNISWAP_API_KEY=

# LLM Provider (optional — pick one, or use Claude CLI as default)
# Priority: Bankr Gateway → Anthropic → OpenAI → Claude CLI
#
# Anthropic API (direct):
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
#
# OpenAI API (or any OpenAI-compatible: Groq, Together, Ollama):
# OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
#
# Local Ollama:
# OPENAI_API_KEY=ollama
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_MODEL=llama3.1
